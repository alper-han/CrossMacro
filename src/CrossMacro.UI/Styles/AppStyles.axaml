<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Composition root for UI styles. Keep include order stable to preserve selector precedence. -->
    <StyleInclude Source="/Styles/Base/Foundations.axaml"/>
    <StyleInclude Source="/Styles/Components/Buttons.axaml"/>
    <StyleInclude Source="/Styles/Components/ListsAndNavigation.axaml"/>
    <StyleInclude Source="/Styles/Components/Inputs.axaml"/>
    <StyleInclude Source="/Styles/Components/SelectionControls.axaml"/>
    <StyleInclude Source="/Styles/Components/ScrollAndPickers.axaml"/>
    <StyleInclude Source="/Styles/Components/Editor.axaml"/>
    <StyleInclude Source="/Styles/Components/HotkeyCapture.axaml"/>
    <StyleInclude Source="/Styles/Components/TemplateOverrides.axaml"/>
</Styles>
