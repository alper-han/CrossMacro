<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- NumericUpDown Style -->
    <Style Selector="NumericUpDown">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- Fallback focus ring for Fluent template variations where border part names differ. -->
    <Style Selector="NumericUpDown:focus-within /template/ Border">
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <!-- Keep NumericUpDown spinner buttons visually stable (no hover blink). -->
    <Style Selector="NumericUpDown /template/ RepeatButton">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions/>
        </Setter>
    </Style>

    <Style Selector="NumericUpDown /template/ RepeatButton:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="NumericUpDown /template/ RepeatButton:pressed">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <!-- TextBox Style -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>
</Styles>
