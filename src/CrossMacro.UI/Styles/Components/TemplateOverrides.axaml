<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Template-part selectors are intentionally centralized in this file.
         These overrides exist only where Fluent templates do not expose equivalent high-level properties. -->

    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}"/>
    </Style>

    <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}"/>
    </Style>

    <Style Selector="Button.success:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SuccessHoverBrush}"/>
    </Style>

    <Style Selector="Button.success:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SuccessPressedBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SuccessPressedBrush}"/>
    </Style>

    <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerHoverBrush}"/>
    </Style>

    <Style Selector="Button.danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerPressedBrush}"/>
    </Style>

    <!-- Keep row-level danger actions subtle while preserving full danger styling
         for standalone destructive buttons. -->
    <Style Selector="Button.row-action.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Button.row-action.danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Button.row-select:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="Button.row-select:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="ToggleButton.pane-toggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
    </Style>

    <Style Selector="ToggleButton.pane-toggle:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="ToggleButton.pane-toggle:checked:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
    </Style>

    <Style Selector="Button.recording-toggle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryHoverBrush}"/>
    </Style>

    <Style Selector="Button.recording-toggle:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryPressedBrush}"/>
    </Style>

    <Style Selector="Button.recording-toggle.recording:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerHoverBrush}"/>
    </Style>

    <Style Selector="Button.recording-toggle.recording:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerPressedBrush}"/>
    </Style>

    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="Button.primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="NumericUpDown:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="NumericUpDown:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="NumericUpDown /template/ Border#PART_BorderElement">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="NumericUpDown /template/ RepeatButton /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="NumericUpDown /template/ RepeatButton:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="NumericUpDown /template/ RepeatButton:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- Keep NumericUpDown inner TextBox stable (no hover/focus blink). -->
    <Style Selector="TextBox#PART_TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox#PART_TextBox /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Transitions">
            <Transitions/>
        </Setter>
    </Style>

    <Style Selector="TextBox#PART_TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="CheckBox /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="CheckBox:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="CheckBox:checked:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="CheckBox:unchecked:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="CheckBox:indeterminate:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>

    <Style Selector="RadioButton /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style Selector="RadioButton:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>

    <Style Selector="RadioButton:checked:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>

    <Style Selector="TimePicker:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="TimePicker:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="TimePicker:pressed /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="TimePicker /template/ Border#PART_BorderElement">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="DatePicker:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>

    <Style Selector="DatePicker:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="DatePicker:pressed /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
    </Style>

    <Style Selector="DatePicker /template/ Border#PART_BorderElement">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
</Styles>
