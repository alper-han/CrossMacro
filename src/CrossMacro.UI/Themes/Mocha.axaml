<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <x:String x:Key="Theme.Name">Mocha</x:String>
    <!-- Catppuccin Mocha Palette -->
    <!-- Primary Colors (Blue for Primary) -->
    <Color x:Key="PrimaryColor">#cba6f7</Color>
    <Color x:Key="PrimaryHoverColor">#dbc2fa</Color>
    <Color x:Key="PrimaryPressedColor">#b581f4</Color>

    <!-- Success/Recording (Green) -->
    <Color x:Key="SuccessColor">#a6e3a1</Color>
    <Color x:Key="SuccessHoverColor">#bceab9</Color>
    <Color x:Key="SuccessPressedColor">#a6e3a1</Color>

    <!-- Danger/Stop (Red) -->
    <Color x:Key="DangerColor">#f38ba8</Color>
    <Color x:Key="DangerHoverColor">#f6a7bd</Color>
    <Color x:Key="DangerPressedColor">#f38ba8</Color>

    <!-- Background (Base) -->
    <Color x:Key="BackgroundColor">#1e1e2e</Color>
    <Color x:Key="SurfaceColor">#181825</Color> <!-- Mantle -->
    <Color x:Key="SurfaceHoverColor">#313244</Color> <!-- Surface0 -->

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#cdd6f4</Color>
    <Color x:Key="TextSecondaryColor">#a6adc8</Color> <!-- Subtext0 -->

    <!-- Warning (Yellow/Peach) -->
    <Color x:Key="WarningColor">#f9e2af</Color>
    <Color x:Key="WarningHoverColor">#fbeccb</Color>

    <!-- Accent (Mauve) -->
    <Color x:Key="AccentColor">#cba6f7</Color>

    <!-- Fluent system accent overrides -->
    <Color x:Key="SystemAccentColor">#cba6f7</Color>
    <Color x:Key="SystemAccentColorDark1">#b581f4</Color>
    <Color x:Key="SystemAccentColorDark2">#b581f4</Color>
    <Color x:Key="SystemAccentColorDark3">#b581f4</Color>
    <Color x:Key="SystemAccentColorLight1">#dbc2fa</Color>
    <Color x:Key="SystemAccentColorLight2">#dbc2fa</Color>
    <Color x:Key="SystemAccentColorLight3">#dbc2fa</Color>

    <!-- Text on colored backgrounds (buttons, toggles, badges) -->
    <Color x:Key="TextOnPrimaryColor">#1e1e2e</Color>
    <Color x:Key="TextOnSuccessColor">#1e1e2e</Color>
    <Color x:Key="TextOnDangerColor">#1e1e2e</Color>
    <Color x:Key="TextOnWarningColor">#1e1e2e</Color>

    <!-- Fluent Slider Overrides -->
    <SolidColorBrush x:Key="SliderThumbBackground" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="SliderThumbBackgroundDisabled" Color="{StaticResource TextSecondaryColor}"/>

    <SolidColorBrush x:Key="SliderTrackFill" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SliderTrackFillPointerOver" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SliderTrackFillPressed" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SliderTrackFillDisabled" Color="{StaticResource SurfaceHoverColor}"/>

    <SolidColorBrush x:Key="SliderTrackValueFill" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="SliderTrackValueFillDisabled" Color="{StaticResource TextSecondaryColor}"/>

    <SolidColorBrush x:Key="SliderTickBarFill" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="SliderTickBarFillDisabled" Color="{StaticResource TextSecondaryColor}"/>
    <!-- End Fluent Slider Overrides -->

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="{StaticResource PrimaryPressedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="{StaticResource SuccessHoverColor}"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="{StaticResource SuccessPressedColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHoverColor}"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="{StaticResource DangerPressedColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="{StaticResource WarningHoverColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="{StaticResource TextOnPrimaryColor}"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="{StaticResource TextOnSuccessColor}"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="{StaticResource TextOnDangerColor}"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="{StaticResource TextOnWarningColor}"/>
</ResourceDictionary>
