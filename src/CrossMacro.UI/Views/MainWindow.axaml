<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CrossMacro.UI.ViewModels"

        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="600"
        x:Class="CrossMacro.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/mouse-icon.png"
        Title="CrossMacro"
        Width="700" Height="600"
        MinWidth="700" MinHeight="600"
        Background="{DynamicResource BackgroundBrush}"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        SystemDecorations="None"
        CanResize="False"
        FontFamily="{StaticResource StandardFont}">

    <Design.DataContext>
        <vm:DesignMainWindowViewModel/>
    </Design.DataContext>

    <SplitView DisplayMode="CompactInline"
               IsPaneOpen="{Binding IsPaneOpen}"
               OpenPaneLength="200"
               CompactPaneLength="76"
               Background="{DynamicResource BackgroundBrush}"
               PaneBackground="{DynamicResource SurfaceBrush}">
        
        <SplitView.Pane>
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header Row with Toggle and Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,16,0,8">
                    <ToggleButton IsChecked="{Binding IsPaneOpen}"
                                  Classes="pane-toggle"
                                  Background="Transparent"
                                  Width="32" Height="32"
                                  CornerRadius="6"
                                  Padding="4"
                                  Margin="19,0,0,0"
                                  HorizontalAlignment="Left">
                        <PathIcon Data="M3,6H21V8H3V6M3,11H21V13H3V11M3,16H21V18H3V16Z"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Width="16" Height="16"/>
                    </ToggleButton>
                    
                    <!-- CrossMacro Title (visible when pane is open) -->
                    <TextBlock Text="CrossMacro"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               IsVisible="{Binding IsPaneOpen}"/>
                </StackPanel>
                
                <!-- Navigation List (Top) -->
                <ListBox Grid.Row="1" 
                         Name="TopNavListBox"
                         Classes="nav-list"
                         ItemsSource="{Binding TopNavigationItems}" 
                         SelectedItem="{Binding SelectedTopItem}"
                         Background="Transparent"
                         SelectionMode="Single"
                         VerticalAlignment="Top"
                         Margin="0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding Label}"
                                        ToolTip.ShowDelay="400">
                                <Border Width="32" Height="32" Background="Transparent">
                                     <TextBlock Text="{Binding Icon}" 
                                               FontSize="20" 
                                               Classes="emoji-icon"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding $parent[SplitView].IsPaneOpen}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Navigation List (Bottom/Settings) -->
                <ListBox Grid.Row="2" 
                         Name="BottomNavListBox"
                         Classes="nav-list"
                         ItemsSource="{Binding BottomNavigationItems}" 
                         SelectedItem="{Binding SelectedBottomItem}"
                         Background="Transparent"
                         SelectionMode="Single"
                         VerticalAlignment="Bottom"
                         Margin="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center"
                                        ToolTip.Tip="{Binding Label}"
                                        ToolTip.ShowDelay="400">
                                <Border Width="32" Height="32" Background="Transparent">
                                     <TextBlock Text="{Binding Icon}" 
                                               FontSize="20" 
                                               Classes="emoji-icon"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Label}" 
                                           VerticalAlignment="Center" 
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding $parent[SplitView].IsPaneOpen}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                
                <!-- Window Title Bar Area (Drag Handle & Controls) -->
                <Grid Grid.Row="0" Height="40" Background="Transparent" ColumnDefinitions="*,Auto">
                    <Border Background="Transparent" PointerPressed="OnTitleBarPointerPressed"/>
                    
                    <!-- Window Controls -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,0,10,0"
                                IsVisible="{Binding IsCloseButtonVisible}">
                        
                        <!-- Minimize Button -->
                        <Button Width="32" Height="32"
                                Classes="titlebar-button"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Click="OnMinimizeWindow"
                                ToolTip.Tip="Minimize">
                            <TextBlock Text="─" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        
                        <!-- Close Button -->
                        <Button Width="32" Height="32"
                                Classes="titlebar-button window-close"
                                Background="Transparent"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Click="OnCloseApp"
                                ToolTip.Tip="Close">
                            <TextBlock Text="✕" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Warning Banner -->
                <Border Grid.Row="1"
                        Classes="notice-card warning"
                        IsVisible="{Binding HasExtensionWarning}"
                        Margin="16,0,16,10">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0"
                                   Text="⚠️"
                                   Classes="emoji-icon notice-icon warning"
                                   Margin="0,0,10,0"/>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="GNOME Extension"
                                       Classes="notice-title"/>
                            <TextBlock Text="{Binding ExtensionWarning}"
                                       Classes="notice-message"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content Display -->
                <!-- Added stretch alignment and adjusted margins -->
                <TransitioningContentControl Grid.Row="2" 
                                           Content="{Binding CurrentPage}" 
                                           Margin="16,0,16,16" 
                                           HorizontalAlignment="Stretch" 
                                           VerticalAlignment="Stretch">
                     <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:00:00.250" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>

                <!-- Footer (Version / Status) -->
                <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="24,0,24,20" VerticalAlignment="Bottom">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🖱️ " FontSize="12" Classes="emoji-icon"/>
                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="CrossMacro "/><Run Text="{Binding AppVersion}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="2" 
                               Text="{Binding GlobalStatus}" 
                               Foreground="{DynamicResource TextSecondaryBrush}" 
                               FontSize="11" 
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
                
                <!-- Update Notification (Overlay) -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SurfaceColor}"
                        BorderBrush="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,20,20"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        IsVisible="{Binding IsUpdateNotificationVisible}"
                        BoxShadow="{DynamicResource ShadowOverlayCard}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                        </Transitions>
                    </Border.Transitions>
                    
                    <StackPanel Spacing="8" Width="240">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Update Available" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LatestVersion, StringFormat='v0 is available'}" 
                                          FontSize="12" 
                                          Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            
                            <Button Grid.Column="1" 
                                    Command="{Binding DismissUpdateNotification}"
                                    Background="Transparent"
                                    Padding="4"
                                    VerticalAlignment="Top"
                                    Margin="8,-4,-4,0">
                                <TextBlock Text="✕" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                        
                        <Button Command="{Binding OpenUpdateUrl}"
                                HorizontalAlignment="Stretch"
                                Background="{DynamicResource PrimaryBrush}"
                                Foreground="{DynamicResource TextOnPrimaryBrush}"
                                CornerRadius="4"
                                Padding="6">
                            <TextBlock Text="View on GitHub" 
                                      HorizontalAlignment="Center" 
                                      FontSize="12"
                                      FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- App Notification (Overlay) -->
                <Border Grid.Row="2"
                        Classes="notice-card floating"
                        Classes.success="{Binding IsAppNotificationSuccess}"
                        Classes.warning="{Binding IsAppNotificationWarning}"
                        Classes.error="{Binding IsAppNotificationError}"
                        Padding="12"
                        Margin="0,8,20,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        MaxWidth="360"
                        IsVisible="{Binding IsAppNotificationVisible}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding AppNotificationIcon}"
                                   Classes="emoji-icon notice-icon"
                                   Classes.success="{Binding IsAppNotificationSuccess}"
                                   Classes.warning="{Binding IsAppNotificationWarning}"
                                   Classes.error="{Binding IsAppNotificationError}"
                                   VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="{Binding AppNotificationTitle}"
                                       Classes="notice-title"/>
                            <TextBlock Text="{Binding AppNotificationMessage}"
                                       Classes="notice-message"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Classes="flat titlebar-button"
                                Padding="4"
                                VerticalAlignment="Top"
                                Click="OnDismissAppNotification"
                                ToolTip.Tip="Dismiss">
                            <TextBlock Text="✕"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>
                </Border>

            </Grid>
        </SplitView.Content>

    </SplitView>

</Window>
