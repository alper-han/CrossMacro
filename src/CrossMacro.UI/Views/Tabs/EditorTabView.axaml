<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossMacro.UI.ViewModels"
             xmlns:local="using:CrossMacro.UI.Views.Tabs"
             xmlns:localization="using:CrossMacro.UI.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
             x:Class="CrossMacro.UI.Views.Tabs.EditorTabView"
             x:DataType="vm:EditorViewModel">

    <Design.DataContext>
        <vm:DesignEditorViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <local:NullableIntConverter x:Key="NullableIntConverter"/>
        <local:IndentLevelToMarginConverter x:Key="IndentLevelToMarginConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Main Content: Action List + Properties -->
        <Grid Grid.Row="0" ColumnDefinitions="1*,1*">

            <!-- Left: Action List -->
            <Border Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="{localization:Loc Editor_Actions}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <ListBox Grid.Row="1"
                             ItemsSource="{Binding ActionListItems}"
                             SelectedItem="{Binding SelectedActionListItem}"
                             Classes="editor-action-list"
                             Background="Transparent"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:EditorActionListItem">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6"
                                            Margin="{Binding IndentLevel, Converter={StaticResource IndentLevelToMarginConverter}}">
                                    <Border Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="3"
                                            Padding="6,2"
                                            VerticalAlignment="Center"
                                            MinWidth="24">
                                        <TextBlock Text="{Binding Index}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Action List Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                        <Button Command="{Binding RemoveAction}"
                                Classes="danger compact"
                                IsEnabled="{Binding HasSelectedAction}"
                                ToolTip.Tip="{localization:Loc Editor_RemoveActionTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="−"/>
                                <TextBlock Text="{localization:Loc Editor_Remove}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding RemoveBlock}"
                                Classes="danger compact"
                                IsEnabled="{Binding CanRemoveBlock}"
                                ToolTip.Tip="{localization:Loc Editor_RemoveBlockTooltip}">
                            <TextBlock Text="{localization:Loc Editor_Block}"/>
                        </Button>
                        <Button Command="{Binding MoveUp}"
                                Classes="secondary compact"
                                IsEnabled="{Binding HasSelectedAction}"
                                ToolTip.Tip="{localization:Loc Editor_MoveUpTooltip}">
                            <TextBlock Text="↑"/>
                        </Button>
                        <Button Command="{Binding MoveDown}"
                                Classes="secondary compact"
                                IsEnabled="{Binding HasSelectedAction}"
                                ToolTip.Tip="{localization:Loc Editor_MoveDownTooltip}">
                            <TextBlock Text="↓"/>
                        </Button>
                        <Button Command="{Binding DuplicateAction}"
                                Classes="secondary compact"
                                IsEnabled="{Binding HasSelectedAction}"
                                ToolTip.Tip="{localization:Loc Editor_DuplicateTooltip}">
                            <TextBlock Text="📋" Classes="emoji-icon"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Right: Properties Panel -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16">

                        <!-- Add New Action Section -->
                        <Border Background="{DynamicResource SurfaceHoverBrush}" CornerRadius="6" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{localization:Loc Editor_AddNewAction}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <ComboBox ItemsSource="{Binding AddableActionTypes}"
                                          SelectedItem="{Binding NewActionType}"
                                          Background="{DynamicResource SurfaceBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={x:Static local:ActionTypeConverters.DisplayText}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            <Button Command="{Binding AddAction}"
                                    Classes="primary"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                    <TextBlock Text="+"/>
                                    <TextBlock Text="{localization:Loc Editor_AddAction}"/>
                                </StackPanel>
                            </Button>
                            </StackPanel>
                        </Border>

                        <!-- Selected Action Properties -->
                        <StackPanel Spacing="12" IsVisible="{Binding HasSelectedAction}">
                            <TextBlock Text="{localization:Loc Editor_SelectedActionProperties}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>

                            <!-- Action Type (Read-only display) -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="{localization:Loc Editor_Type}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="4" Padding="8,6">
                                    <TextBlock Text="{Binding SelectedAction.Type, Converter={x:Static local:ActionTypeConverters.DisplayText}}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <Button Command="{Binding InsertElseBlock}"
                                    Classes="secondary compact"
                                    IsVisible="{Binding CanInsertElseBlock}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center">
                                <TextBlock Text="{localization:Loc Editor_InsertElseBlock}"/>
                            </Button>

                            <StackPanel Spacing="4" IsVisible="{Binding ShowCurrentPositionToggle}">
                                <CheckBox IsChecked="{Binding SelectedAction.UseCurrentPosition}"
                                          Content="{Binding CurrentPositionToggleLabel}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{localization:Loc Editor_CurrentPositionHint}"
                                           Classes="caption"
                                           IsVisible="{Binding SelectedAction.UseCurrentPosition}"/>
                            </StackPanel>

                            <!-- Coordinates (MouseMove, MouseClick, MouseDown, MouseUp) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowCoordinates}">
                                <TextBlock Text="{localization:Loc Editor_Coordinates}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <TextBox Text="{Binding SelectedAction.X, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="X"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding SelectedAction.Y, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Y"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                </Grid>
                                <Button Command="{Binding CaptureMouseAsync}"
                                        Classes="primary compact"
                                        IsVisible="{Binding !IsCapturing}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Text="📍" Classes="emoji-icon"/>
                                        <TextBlock Text="{localization:Loc Editor_CapturePosition}"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding CancelCapture}"
                                        Classes="danger compact"
                                        IsVisible="{Binding IsCapturing}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Text="❌" Classes="emoji-icon"/>
                                        <TextBlock Text="{localization:Loc Editor_CancelCapture}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Absolute/Relative Toggle (all coordinate-bearing mouse actions) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowCoordModeToggle}">
                                <TextBlock Text="{localization:Loc Editor_CoordinateMode}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <RadioButton GroupName="CoordMode"
                                                 IsChecked="{Binding SelectedAction.IsAbsolute}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock Text="{localization:Loc Editor_Absolute}" FontSize="12"/>
                                    </RadioButton>
                                    <RadioButton GroupName="CoordMode"
                                                 IsChecked="{Binding !SelectedAction.IsAbsolute}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}">
                                        <TextBlock Text="{localization:Loc Editor_Relative}" FontSize="12"/>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>

                            <!-- Mouse Button (MouseClick, MouseDown, MouseUp) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowMouseButton}">
                                <TextBlock Text="{localization:Loc Editor_MouseButton}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding MouseButtons}"
                                          SelectedItem="{Binding SelectedAction.Button}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- Key Code (KeyPress, KeyDown, KeyUp) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowKeyCode}">
                                <TextBlock Text="{localization:Loc Editor_Key}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <Grid ColumnDefinitions="80,8,*">
                                    <TextBox Text="{Binding SelectedAction.KeyCode, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{localization:Loc Editor_KeyPlaceholder}"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"
                                             MaxLength="3"/>
                                    <Border Grid.Column="2"
                                            Background="{DynamicResource SurfaceBrush}"
                                            CornerRadius="4"
                                            Padding="12,6">
                                        <TextBlock Text="{Binding SelectedAction.KeyName, FallbackValue={localization:Loc Editor_KeyFallback}}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                                <Button Command="{Binding CaptureKeyAsync}"
                                        Classes="primary compact"
                                        IsVisible="{Binding !IsCapturing}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Text="⌨️" Classes="emoji-icon"/>
                                        <TextBlock Text="{localization:Loc Editor_CaptureKey}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Delay (Delay action only) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowDelay}">
                                <CheckBox IsChecked="{Binding SelectedAction.UseRandomDelay}"
                                          Content="{localization:Loc Editor_RandomizeDelay}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>

                                <StackPanel Spacing="4" IsVisible="{Binding ShowFixedDelayInput}">
                                    <TextBlock Text="{localization:Loc Editor_DelayMs}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBox Text="{Binding SelectedAction.DelayMs, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{localization:Loc Editor_DelayPlaceholder}"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                </StackPanel>

                                <StackPanel Spacing="4" IsVisible="{Binding ShowRandomDelayOptions}">
                                    <TextBlock Text="{localization:Loc Editor_RandomDelayRangeMs}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <Grid ColumnDefinitions="*,8,*">
                                        <TextBox Text="{Binding SelectedAction.RandomDelayMinMs, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="{localization:Loc Editor_Min}"
                                                 Background="{DynamicResource SurfaceHoverBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding SelectedAction.RandomDelayMaxMs, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="{localization:Loc Editor_Max}"
                                                 Background="{DynamicResource SurfaceHoverBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <!-- Scroll Amount (ScrollVertical, ScrollHorizontal) -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowScrollAmount}">
                                <TextBlock Text="{localization:Loc Editor_ScrollAmount}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox Text="{Binding SelectedAction.ScrollAmount, Converter={StaticResource NullableIntConverter}, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_Amount}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                                <TextBlock Text="{localization:Loc Editor_ScrollHint}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>

                            <!-- Text input -->
                            <StackPanel Spacing="4" IsVisible="{Binding ShowTextInput}">
                                <TextBlock Text="{Binding TextInputLabel}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox Text="{Binding SelectedAction.Text, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{Binding TextInputWatermark}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"
                                         AcceptsReturn="{Binding TextInputAcceptsReturn}"
                                         TextWrapping="NoWrap"
                                         MaxLength="500"/>
                                <TextBlock Text="{Binding TextInputHint}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Set variable -->
                            <StackPanel Spacing="6" IsVisible="{Binding ShowSetVariableFields}">
                                <TextBlock Text="{localization:Loc Editor_SetVariable}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox Text="{Binding SelectedAction.ScriptVariableName, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_VariableNamePlaceholder}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                                <ComboBox ItemsSource="{Binding AvailableVariableNames}"
                                          SelectedItem="{Binding SelectedSetVariableSuggestion}"
                                          IsVisible="{Binding ShowSetVariablePicker}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch"/>
                                <ComboBox ItemsSource="{Binding ScriptValueTypes}"
                                          SelectedItem="{Binding SelectedAction.ScriptValueType}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding SelectedAction.ScriptValue, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_Value}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                                <TextBlock Text="{localization:Loc Editor_SetVariableHint}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Increment / Decrement -->
                            <StackPanel Spacing="6" IsVisible="{Binding ShowIncDecFields}">
                                <TextBlock Text="{localization:Loc Editor_VariableUpdate}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox Text="{Binding SelectedAction.ScriptVariableName, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_VariableNamePlaceholder}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                                <ComboBox ItemsSource="{Binding AvailableVariableNames}"
                                          SelectedItem="{Binding SelectedIncDecVariableSuggestion}"
                                          IsVisible="{Binding ShowIncDecVariablePicker}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch"/>
                                <ComboBox ItemsSource="{Binding ScriptNumericSourceTypes}"
                                          SelectedItem="{Binding SelectedAction.ScriptNumericSourceType}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding SelectedAction.ScriptNumericValue, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_AmountOrVariable}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                                <TextBlock Text="{localization:Loc Editor_IncrementDecrementHint}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Repeat -->
                            <StackPanel Spacing="6" IsVisible="{Binding ShowRepeatFields}">
                                <TextBlock Text="{localization:Loc Editor_RepeatBlock}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <ComboBox ItemsSource="{Binding ScriptNumericSourceTypes}"
                                          SelectedItem="{Binding SelectedAction.ScriptNumericSourceType}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding SelectedAction.ScriptNumericValue, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_CountOrVariable}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                            </StackPanel>

                            <!-- If / While condition -->
                            <StackPanel Spacing="6" IsVisible="{Binding ShowConditionFields}">
                                <TextBlock Text="{localization:Loc Editor_Condition}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBlock Text="{localization:Loc Editor_LeftOperand}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <ComboBox ItemsSource="{Binding ScriptOperandTypes}"
                                              SelectedItem="{Binding SelectedAction.ScriptLeftOperandType}"
                                              Background="{DynamicResource SurfaceHoverBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding SelectedAction.ScriptLeftOperand, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{localization:Loc Editor_LeftValue}"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                </Grid>
                                <ComboBox ItemsSource="{Binding AvailableVariableNames}"
                                          SelectedItem="{Binding SelectedConditionLeftVariableSuggestion}"
                                          IsVisible="{Binding ShowConditionLeftVariablePicker}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch"/>
                                <ComboBox ItemsSource="{Binding ScriptConditionOperators}"
                                          SelectedItem="{Binding SelectedAction.ScriptConditionOperator}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{localization:Loc Editor_RightOperand}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <ComboBox ItemsSource="{Binding ScriptOperandTypes}"
                                              SelectedItem="{Binding SelectedAction.ScriptRightOperandType}"
                                              Background="{DynamicResource SurfaceHoverBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding SelectedAction.ScriptRightOperand, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{localization:Loc Editor_RightValue}"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                </Grid>
                                <ComboBox ItemsSource="{Binding AvailableVariableNames}"
                                          SelectedItem="{Binding SelectedConditionRightVariableSuggestion}"
                                          IsVisible="{Binding ShowConditionRightVariablePicker}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <!-- For -->
                            <StackPanel Spacing="6" IsVisible="{Binding ShowForFields}">
                                <TextBlock Text="{localization:Loc Editor_ForBlock}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox Text="{Binding SelectedAction.ForVariableName, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="{localization:Loc Editor_LoopVariablePlaceholder}"
                                         Background="{DynamicResource SurfaceHoverBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         CornerRadius="4"
                                         Padding="8,6"/>
                                <ComboBox ItemsSource="{Binding AvailableVariableNames}"
                                          SelectedItem="{Binding SelectedForVariableSuggestion}"
                                          IsVisible="{Binding ShowForVariablePicker}"
                                          Background="{DynamicResource SurfaceHoverBrush}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"
                                          HorizontalAlignment="Stretch"/>

                                <TextBlock Text="{localization:Loc Editor_Start}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <ComboBox ItemsSource="{Binding ScriptNumericSourceTypes}"
                                              SelectedItem="{Binding SelectedAction.ForStartType}"
                                              Background="{DynamicResource SurfaceHoverBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding SelectedAction.ForStartValue, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{localization:Loc Editor_Start}"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                </Grid>

                                <TextBlock Text="{localization:Loc Editor_End}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <Grid ColumnDefinitions="*,8,*">
                                    <ComboBox ItemsSource="{Binding ScriptNumericSourceTypes}"
                                              SelectedItem="{Binding SelectedAction.ForEndType}"
                                              Background="{DynamicResource SurfaceHoverBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding SelectedAction.ForEndValue, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="{localization:Loc Editor_End}"
                                             Background="{DynamicResource SurfaceHoverBrush}"
                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                             BorderThickness="0"
                                             CornerRadius="4"
                                             Padding="8,6"/>
                                </Grid>

                                <CheckBox IsChecked="{Binding SelectedAction.ForHasStep}"
                                           Content="{localization:Loc Editor_UseExplicitStep}"
                                          Foreground="{DynamicResource TextPrimaryBrush}"/>

                                <StackPanel Spacing="4" IsVisible="{Binding ShowForStepFields}">
                                    <Grid ColumnDefinitions="*,8,*">
                                        <ComboBox ItemsSource="{Binding ScriptNumericSourceTypes}"
                                                  SelectedItem="{Binding SelectedAction.ForStepType}"
                                                  Background="{DynamicResource SurfaceHoverBrush}"
                                                  Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding SelectedAction.ForStepValue, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="{localization:Loc Editor_Step}"
                                                 Background="{DynamicResource SurfaceHoverBrush}"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 BorderThickness="0"
                                                 CornerRadius="4"
                                                 Padding="8,6"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- No Selection Message -->
                        <TextBlock Text="{localization:Loc Editor_SelectActionPrompt}"
                                   IsVisible="{Binding !HasSelectedAction}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer: Status + Actions -->
        <Border Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Spacing="8">
                <Border IsVisible="{Binding HasLoadWarnings}"
                        Background="{DynamicResource SurfaceHoverBrush}"
                        CornerRadius="6"
                        Padding="10,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{localization:Loc Editor_RestoreWarnings}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                        <ItemsControl ItemsSource="{Binding LoadWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,Auto">
                    <!-- Undo/Redo + Clear -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding Undo}"
                                Classes="secondary compact"
                                IsEnabled="{Binding CanUndo}"
                                ToolTip.Tip="{localization:Loc Editor_UndoTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="↩"/>
                                <TextBlock Text="{localization:Loc Editor_Undo}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding Redo}"
                                Classes="secondary compact"
                                IsEnabled="{Binding CanRedo}"
                                ToolTip.Tip="{localization:Loc Editor_RedoTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="↪"/>
                                <TextBlock Text="{localization:Loc Editor_Redo}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ClearAll}"
                                Classes="secondary compact"
                                IsEnabled="{Binding HasActions}"
                                ToolTip.Tip="{localization:Loc Editor_ClearAllTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="🗑️" Classes="emoji-icon"/>
                                <TextBlock Text="{localization:Loc Editor_Clear}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Save/Load -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding LoadMacroAsync}"
                                Classes="secondary compact">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="📂" Classes="emoji-icon"/>
                                <TextBlock Text="{localization:Loc Editor_Load}"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SaveMacroAsync}"
                                Classes="primary compact"
                                IsEnabled="{Binding HasActions}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="💾" Classes="emoji-icon"/>
                                <TextBlock Text="{localization:Loc Editor_Save}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
