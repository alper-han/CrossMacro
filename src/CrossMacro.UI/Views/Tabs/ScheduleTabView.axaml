<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossMacro.UI.ViewModels"
             xmlns:core="using:CrossMacro.Core.Models"
             xmlns:local="using:CrossMacro.UI.Views.Tabs"
             xmlns:localization="using:CrossMacro.UI.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CrossMacro.UI.Views.Tabs.ScheduleTabView"
             x:DataType="vm:ScheduleViewModel">

    <Design.DataContext>
        <vm:DesignScheduleViewModel/>
    </Design.DataContext>

    <ScrollViewer Padding="10">
        <StackPanel Spacing="16" Margin="0,0,0,50">
            
            <!-- Task List Section -->
            <Border Background="{DynamicResource SurfaceColor}" CornerRadius="12" Padding="16"
                    x:Name="TaskListBorder">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                  Text="{localization:Loc Schedule_Title}" 
                                  FontWeight="SemiBold" 
                                  Foreground="{DynamicResource TextSecondaryBrush}" 
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding TaskCountText}"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="12"
                                  Margin="0,0,12,0"/>
                        <Button Grid.Column="2" 
                               Command="{Binding AddTaskCommand}"
                               Background="{DynamicResource SurfaceHoverBrush}"
                               CornerRadius="6"
                               Padding="8,4"
                               Cursor="Hand">
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </Button>
                    </Grid>
                    
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:ScheduledTask">
                                <Border Padding="10,8" 
                                        CornerRadius="8" 
                                        Margin="0,2"
                                        Classes="row-item no-hover"
                                        Background="{DynamicResource BackgroundBrush}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                        <!-- Task Info (clickable area for selection) -->
                                        <Button Grid.Column="0" 
                                                Classes="flat row-select"
                                                Background="Transparent"
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding #TaskListBorder.((vm:ScheduleViewModel)DataContext).SelectTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand">
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Name}" 
                                                          FontWeight="Medium"
                                                          FontSize="13"
                                                          TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="11" 
                                                          Foreground="{DynamicResource TextSecondaryBrush}"
                                                          TextTrimming="CharacterEllipsis"
                                                          Text="{Binding Converter={x:Static local:ScheduleTaskConverters.SummaryText}}"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- Toggle Switch -->
                                        <ToggleSwitch Grid.Column="1" 
                                                     IsChecked="{Binding IsEnabled}"
                                                     IsEnabled="{Binding CanBeEnabled}"
                                                     OnContent="" OffContent=""
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,4,0"/>
                                        
                                        <!-- Edit Button -->
                                        <Button Grid.Column="2"
                                                Classes="flat row-action"
                                                Background="Transparent"
                                                Padding="6"
                                                Command="{Binding #TaskListBorder.((vm:ScheduleViewModel)DataContext).SelectTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                ToolTip.Tip="{localization:Loc Schedule_EditTask}">
                                            <TextBlock Text="✏️" FontSize="12" Classes="emoji-icon"/>
                                        </Button>
                                        
                                        <!-- Delete Button -->
                                        <Button Grid.Column="3"
                                                Classes="flat row-action danger"
                                                Background="Transparent"
                                                Padding="6"
                                                Command="{Binding #TaskListBorder.((vm:ScheduleViewModel)DataContext).RemoveTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                ToolTip.Tip="{localization:Loc Schedule_DeleteTask}">
                                            <TextBlock Text="🗑" FontSize="12" Classes="emoji-icon" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
            <!-- Task Settings Section (visible when task selected) -->
            <Border Background="{DynamicResource SurfaceColor}" 
                    CornerRadius="12" 
                    Padding="16"
                    IsVisible="{Binding HasSelectedTask}">
                <StackPanel Spacing="16">
                    <TextBlock Text="{localization:Loc Schedule_TaskSettings}" 
                              FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextSecondaryBrush}" 
                              FontSize="12"/>
                    
                    <!-- Task Name -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{localization:Loc Schedule_Name}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding SelectedTask.Name, Mode=TwoWay, FallbackValue=''}" 
                                PlaceholderText="{localization:Loc Schedule_NamePlaceholder}"/>
                    </StackPanel>
                    
                    <!-- Playback Speed -->
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Classes="label" Text="{localization:Loc Schedule_PlaybackSpeed}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding SelectedTask.PlaybackSpeed, StringFormat='{}{0:0.0}x', FallbackValue='1.0x'}" 
                                      FontWeight="Medium"
                                      FontSize="16"
                                      Foreground="{DynamicResource PrimaryBrush}"/>
                        </Grid>
                        <Slider Value="{Binding SelectedTask.PlaybackSpeed, Mode=TwoWay, FallbackValue=1.0}"
                               Minimum="0.1" 
                               Maximum="10.0" 
                               TickFrequency="0.1"
                               IsSnapToTickEnabled="True"/>
                    </StackPanel>
                    
                    <!-- Macro File -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{localization:Loc Schedule_MacroFile}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Border Grid.Column="0" 
                                   Background="{DynamicResource BackgroundBrush}" 
                                   CornerRadius="6" 
                                   Padding="12,8"
                                   Margin="0,0,8,0">
                                <TextBlock Text="{Binding SelectedMacroFileName, FallbackValue={localization:Loc Schedule_NoFileSelected}}" 
                                          VerticalAlignment="Center"
                                          TextTrimming="CharacterEllipsis"
                                          ToolTip.Tip="{Binding SelectedMacroFilePath, FallbackValue=''}"/>
                            </Border>
                            <Button Grid.Column="1" 
                                   Command="{Binding BrowseMacroCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="📂" Classes="emoji-icon"/>
                                    <TextBlock Text="{localization:Loc Schedule_Browse}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                    
                    <!-- Schedule Type -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="{localization:Loc Schedule_Type}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <RadioButton IsChecked="{Binding IsIntervalSelected, Mode=TwoWay}"
                                        GroupName="ScheduleType">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="⏱️" Classes="emoji-icon"/>
                                    <TextBlock Text="{localization:Loc Schedule_TypeInterval}"/>
                                </StackPanel>
                            </RadioButton>
                            <RadioButton IsChecked="{Binding IsDateTimeSelected, Mode=TwoWay}"
                                        GroupName="ScheduleType">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="📅" Classes="emoji-icon"/>
                                    <TextBlock Text="{localization:Loc Schedule_TypeDateTime}"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Interval Settings -->
            <Border Background="{DynamicResource SurfaceColor}" 
                   CornerRadius="12" 
                   Padding="16">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="HasSelectedTask" FallbackValue="False"/>
                        <Binding Path="IsIntervalSelected" FallbackValue="False"/>
                    </MultiBinding>
                </Border.IsVisible>
                <StackPanel Spacing="12">
                    <TextBlock Text="{localization:Loc Schedule_IntervalSettings}" 
                              FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="12"/>
                    <TextBlock Text="{localization:Loc Schedule_RunEvery}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <NumericUpDown Value="{Binding SelectedTask.IntervalValue, Mode=TwoWay, FallbackValue=1}"
                                      Minimum="1" Maximum="9999"
                                      Width="120"/>
                        <ComboBox SelectedIndex="{Binding SelectedTask.IntervalUnit, Mode=TwoWay, FallbackValue=0}"
                                 Width="120">
                            <ComboBoxItem Content="{localization:Loc Schedule_Seconds}"/>
                            <ComboBoxItem Content="{localization:Loc Schedule_Minutes}"/>
                            <ComboBoxItem Content="{localization:Loc Schedule_Hours}"/>
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- DateTime Settings -->
            <Border Background="{DynamicResource SurfaceColor}" 
                   CornerRadius="12" 
                   Padding="16">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="HasSelectedTask"/>
                        <Binding Path="IsDateTimeSelected"/>
                    </MultiBinding>
                </Border.IsVisible>
                <StackPanel Spacing="12">
                    <TextBlock Text="{localization:Loc Schedule_DateTimeSettings}" 
                              FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="12"/>
                    <TextBlock Text="{localization:Loc Schedule_RunAt}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Vertical" Spacing="12" HorizontalAlignment="Left">
                        <DatePicker SelectedDate="{Binding ScheduledDate, Mode=TwoWay, FallbackValue={x:Null}}"
                                   HorizontalAlignment="Stretch"/>
                        <TimePicker SelectedTime="{Binding ScheduledTime, Mode=TwoWay, FallbackValue={x:Null}}"
                                   UseSeconds="True"
                                   HorizontalAlignment="Stretch"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="💡" FontSize="11" Classes="emoji-icon" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{localization:Loc Schedule_RunOnceTip}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Status Section -->
            <Border Background="{DynamicResource SurfaceColor}" 
                   CornerRadius="12" 
                   Padding="16"
                   IsVisible="{Binding HasSelectedTask}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{localization:Loc Schedule_Status}" 
                              FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="12"/>
                    <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{localization:Loc Schedule_LastRun}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                  Text="{Binding SelectedTask.LastRunTime, StringFormat='{}{0:G}', TargetNullValue={localization:Loc Schedule_Never}, FallbackValue={localization:Loc Schedule_Never}}" 
                                  FontSize="12"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{localization:Loc Schedule_NextRun}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                  Text="{Binding SelectedTask.NextRunTime, StringFormat='{}{0:G}', TargetNullValue={localization:Loc Schedule_NotScheduled}, FallbackValue={localization:Loc Schedule_NotScheduled}}" 
                                  FontSize="12"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{localization:Loc Schedule_StatusLabel}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                  Text="{Binding SelectedTask.LastStatus, TargetNullValue={localization:Loc Schedule_StatusPlaceholder}, FallbackValue={localization:Loc Schedule_StatusPlaceholder}}" 
                                  FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Save Button -->
            <Button Command="{Binding SaveCommand}"
                   Classes="primary"
                   HorizontalAlignment="Right"
                   IsVisible="{Binding HasSelectedTask}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="💾" Classes="emoji-icon"/>
                    <TextBlock Text="{localization:Loc Schedule_SaveAllTasks}"/>
                </StackPanel>
            </Button>
            
            <!-- Empty State -->
            <Border Background="{DynamicResource SurfaceColor}" 
                    CornerRadius="12" 
                    Padding="32"
                    IsVisible="{Binding !HasSelectedTask}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="🕐" FontSize="48" Classes="emoji-icon" HorizontalAlignment="Center"/>
                    <TextBlock Text="{localization:Loc Schedule_NoTaskSelected}" 
                              FontSize="16" 
                              FontWeight="Medium"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="{localization:Loc Schedule_SelectTaskHint}" 
                              FontSize="12"
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
