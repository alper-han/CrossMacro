<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossMacro.UI.ViewModels"
             xmlns:controls="using:CrossMacro.UI.Controls"
             xmlns:localization="using:CrossMacro.UI.Localization"
             xmlns:icons="using:CrossMacro.UI.Icons"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="400"
             x:Class="CrossMacro.UI.Views.Tabs.SettingsTabView"
             x:DataType="vm:SettingsViewModel">

    <Design.DataContext>
        <vm:DesignSettingsViewModel/>
    </Design.DataContext>

    <Panel>
        <ScrollViewer Padding="10" 
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20">

                <!-- Hotkey Info -->
                <Border Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{localization:Loc Settings_GlobalHotkeys}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" Margin="0,4,0,0">
                             <controls:HotkeyCapture Grid.Row="0" Grid.Column="0"
                                                     x:Name="RecordingHotkeyCapture"
                                                     Hotkey="{Binding RecordingHotkey, Mode=TwoWay}"
                                                    LocalizationService="{Binding LocalizationService}"
                                                    GlobalHotkeyService="{Binding GlobalHotkeyService}"
                                                    Margin="0,0,12,8"
                                                    MinWidth="140"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{localization:Loc Settings_ToggleRecording}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>

                             <controls:HotkeyCapture Grid.Row="1" Grid.Column="0"
                                                     x:Name="PlaybackHotkeyCapture"
                                                     Hotkey="{Binding PlaybackHotkey, Mode=TwoWay}"
                                                    LocalizationService="{Binding LocalizationService}"
                                                    GlobalHotkeyService="{Binding GlobalHotkeyService}"
                                                    Margin="0,0,12,8"
                                                    MinWidth="140"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{localization:Loc Settings_TogglePlayback}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>

                             <controls:HotkeyCapture Grid.Row="2" Grid.Column="0"
                                                     x:Name="PauseHotkeyCapture"
                                                     Hotkey="{Binding PauseHotkey, Mode=TwoWay}"
                                                    LocalizationService="{Binding LocalizationService}"
                                                    GlobalHotkeyService="{Binding GlobalHotkeyService}"
                                                    Margin="0,0,12,0"
                                                    MinWidth="140"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{localization:Loc Settings_PauseResumePlayback}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Tray Icon Settings -->
                <Border Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="16">
                        <!-- Tray Icon (hidden in Flatpak - D-Bus StatusNotifierItem not supported) -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsVisible="{Binding IsTraySettingsVisible}">
                            <TextBlock Grid.Column="0"
                                       Text="{localization:Loc Settings_EnableTrayIcon}"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>

                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding EnableTrayIcon}"
                                         OnContent=""
                                         OffContent=""
                                         VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Start minimized depends on tray support because it starts hidden to tray when available -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsVisible="{Binding IsTraySettingsVisible}">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{localization:Loc Settings_StartMinimized}"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{localization:Loc Settings_StartMinimizedDescription}"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            TextWrapping="Wrap"/>
                            </StackPanel>

                            <ToggleSwitch Grid.Column="1"
                                         IsChecked="{Binding StartMinimized}"
                                         OnContent=""
                                         OffContent=""
                                         VerticalAlignment="Center"/>
                        </Grid>
                        
                        <!-- Text Expansion -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <TextBlock Grid.Column="0" 
                                       Text="{localization:Loc Settings_EnableTextExpansion}" 
                                       FontWeight="Medium" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                                      
                            <ToggleSwitch Grid.Column="1" 
                                         IsChecked="{Binding EnableTextExpansion}"
                                         OnContent="" 
                                         OffContent=""
                                         VerticalAlignment="Center"/>
                        </Grid>
                        
                        <!-- Update Check -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12" IsVisible="{Binding IsUpdateSettingsVisible}">
                            <TextBlock Grid.Column="0" 
                                       Text="{localization:Loc Settings_CheckForUpdates}" 
                                       FontWeight="Medium" 
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                                      
                            <ToggleSwitch Grid.Column="1" 
                                         IsChecked="{Binding CheckForUpdates}"
                                         OnContent="" 
                                         OffContent=""
                                         VerticalAlignment="Center"/>
                        </Grid>
                        
                        <!-- Log Level -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{localization:Loc Settings_LogLevel}" 
                                           FontWeight="Medium" 
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{localization:Loc Settings_LogLevelDescription}" 
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LogLevels}"
                                      SelectedItem="{Binding SelectedLogLevel}"
                                      Width="150"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Theme -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{localization:Loc Settings_Theme}" 
                                           FontWeight="Medium" 
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{localization:Loc Settings_ThemeDescription}" 
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme}"
                                      Width="150"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{localization:Loc Settings_Language}"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{localization:Loc Settings_LanguageDescription}"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                            TextWrapping="Wrap"/>
                            </StackPanel>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguageOption}"
                                      Width="150"
                                      VerticalAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>


                <!-- Support Section -->
                <Border Background="{DynamicResource SurfaceColor}" CornerRadius="8" Padding="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                            <TextBlock Text="{localization:Loc Settings_SupportTitle}" 
                                      FontWeight="Bold" 
                                      Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="{localization:Loc Settings_SupportDescription}" 
                                      FontSize="12"
                                      TextWrapping="Wrap"
                                      Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </StackPanel>
                        
                        <Button Grid.Column="1" 
                                Command="{Binding OpenGitHub}"
                                Classes="primary"
                                Background="{DynamicResource PrimaryBrush}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{icons:AppIcon GitHub}"
                                          Foreground="{DynamicResource TextOnPrimaryBrush}"
                                          Width="16" Height="16"/>
                                <TextBlock Text="{localization:Loc Settings_StarOnGitHub}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
                
                <!-- Bottom Spacer to ensure scrolling works fully -->
                <Rectangle Height="40" Fill="Transparent"/>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Toast Notification -->
        <Border x:Name="ToastNotification"
                Classes="notice-card floating error"
                Padding="14,12"
                Margin="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsVisible="False">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                </Transitions>
            </Border.Transitions>
            
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" MaxWidth="320">
                <icons:EmojiAppIcon Grid.Column="0"
                                    Icon="Warning"
                                    Width="18"
                                    Height="18"
                                    VerticalAlignment="Top"/>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock x:Name="ToastTitle"
                                Text="{localization:Loc Settings_HotkeyAlreadyAssignedTitle}"
                                Classes="notice-title"/>
                    <TextBlock x:Name="ToastMessage"
                               Text=""
                               Classes="notice-message"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>
    </Panel>

</UserControl>
