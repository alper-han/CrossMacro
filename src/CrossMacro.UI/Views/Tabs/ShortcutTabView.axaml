<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CrossMacro.UI.ViewModels"
             xmlns:core="using:CrossMacro.Core.Models"
             xmlns:controls="using:CrossMacro.UI.Controls"
             xmlns:localization="using:CrossMacro.UI.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="700"
             x:Class="CrossMacro.UI.Views.Tabs.ShortcutTabView"
             x:DataType="vm:ShortcutViewModel">

    <Design.DataContext>
        <vm:DesignShortcutViewModel/>
    </Design.DataContext>

    <ScrollViewer Padding="10">
        <StackPanel Spacing="16" Margin="0,0,0,50">
            
            <!-- Shortcut List Section -->
            <Border Background="{DynamicResource SurfaceColor}" CornerRadius="12" Padding="16"
                    x:Name="ShortcutListBorder">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                  Text="{localization:Loc Shortcut_Title}" 
                                  FontWeight="SemiBold" 
                                  Foreground="{DynamicResource TextSecondaryBrush}" 
                                  FontSize="12"
                                  VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                  Text="{Binding TaskCountText}"
                                  VerticalAlignment="Center"
                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                  FontSize="12"
                                  Margin="0,0,12,0"/>
                        <Button Grid.Column="2" 
                               Command="{Binding AddTaskCommand}"
                               Background="{DynamicResource SurfaceHoverBrush}"
                               CornerRadius="6"
                               Padding="8,4"
                               Cursor="Hand">
                            <TextBlock Text="+" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </Button>
                    </Grid>
                    
                    <ItemsControl ItemsSource="{Binding Tasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:ShortcutTask">
                                <Border Padding="10,8" 
                                        CornerRadius="8" 
                                        Margin="0,2"
                                        Classes="row-item no-hover"
                                        Background="{DynamicResource BackgroundBrush}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                        <!-- Shortcut Info (clickable area for selection) -->
                                        <Button Grid.Column="0" 
                                                Classes="flat row-select"
                                                Background="Transparent"
                                                Padding="0"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding #ShortcutListBorder.((vm:ShortcutViewModel)DataContext).SelectTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand">
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Name, FallbackValue={localization:Loc Shortcut_NameFallback}}" 
                                                          FontWeight="Medium"
                                                          FontSize="13"
                                                          TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Background="{DynamicResource SurfaceHoverBrush}" 
                                                            CornerRadius="4" 
                                                            Padding="6,2"
                                                            IsVisible="{Binding HotkeyString, Converter={x:Static StringConverters.IsNotNullOrEmpty}, FallbackValue=False}">
                                                        <TextBlock Text="{Binding HotkeyString, FallbackValue=''}" 
                                                                   FontSize="11" 
                                                                   FontFamily="Consolas, monospace"
                                                                   Foreground="{DynamicResource PrimaryBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding MacroFilePath, TargetNullValue={localization:Loc Shortcut_NoFile}, FallbackValue={localization:Loc Shortcut_NoFile}}"
                                                               FontSize="11" 
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="200"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- Toggle Switch -->
                                        <ToggleSwitch Grid.Column="1" 
                                                     IsChecked="{Binding IsEnabled}"
                                                     IsEnabled="{Binding CanBeEnabled}"
                                                     OnContent="" OffContent=""
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,4,0"/>
                                        
                                        <!-- Edit Button -->
                                        <Button Grid.Column="2"
                                                Classes="flat row-action"
                                                Background="Transparent"
                                                Padding="6"
                                                Command="{Binding #ShortcutListBorder.((vm:ShortcutViewModel)DataContext).SelectTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                ToolTip.Tip="{localization:Loc Shortcut_EditTooltip}">
                                            <TextBlock Text="✏️" FontSize="12" Classes="emoji-icon"/>
                                        </Button>
                                        
                                        <!-- Delete Button -->
                                        <Button Grid.Column="3"
                                                Classes="flat row-action danger"
                                                Background="Transparent"
                                                Padding="6"
                                                Command="{Binding #ShortcutListBorder.((vm:ShortcutViewModel)DataContext).RemoveTaskCommand}"
                                                CommandParameter="{Binding}"
                                                Cursor="Hand"
                                                ToolTip.Tip="{localization:Loc Shortcut_DeleteTooltip}">
                                            <TextBlock Text="🗑" FontSize="12" Classes="emoji-icon" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            
            <!-- Shortcut Settings Section (visible when shortcut selected) -->
            <Border Background="{DynamicResource SurfaceColor}" 
                    CornerRadius="12" 
                    Padding="16"
                    IsVisible="{Binding HasSelectedTask}">
                <StackPanel Spacing="16">
                    <TextBlock Text="{localization:Loc Shortcut_Settings}" 
                              FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextSecondaryBrush}" 
                              FontSize="12"/>
                    
                    <!-- Shortcut Name -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{localization:Loc Shortcut_Name}" Classes="caption"/>
                        <TextBox Text="{Binding SelectedTask.Name, Mode=TwoWay, FallbackValue=''}" 
                                PlaceholderText="{localization:Loc Shortcut_NamePlaceholder}"/>
                    </StackPanel>
                    
                    <!-- Hotkey Capture -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{localization:Loc Shortcut_Trigger}" Classes="caption"/>
                        <controls:HotkeyCapture x:Name="HotkeyInput"
                                               Hotkey="{Binding SelectedHotkeyString, Mode=TwoWay, FallbackValue=''}"
                                               HotkeyChanged="OnHotkeyChanged"/>
                    </StackPanel>
                    
                    <!-- Playback Speed -->
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Classes="label" Text="{localization:Loc Shortcut_PlaybackSpeed}"/>
                            <TextBlock Grid.Column="1" 
                                      Text="{Binding SelectedTask.PlaybackSpeed, StringFormat='{}{0:0.0}x', FallbackValue='1.0x'}" 
                                      FontWeight="Medium"
                                      FontSize="16"
                                      Foreground="{DynamicResource PrimaryBrush}"/>
                        </Grid>
                        <Slider Value="{Binding SelectedTask.PlaybackSpeed, Mode=TwoWay, FallbackValue=1.0}"
                               Minimum="0.1" 
                               Maximum="10.0" 
                               TickFrequency="0.1"
                               IsSnapToTickEnabled="True"/>
                    </StackPanel>
                    
                    <!-- Loop Playback (same pattern as Playback tab) -->
                    <StackPanel Spacing="12">
                        <CheckBox Content="{localization:Loc Shortcut_LoopPlayback}"
                                  IsChecked="{Binding SelectedTask.IsLoopEnabled, Mode=TwoWay}"/>
                        <StackPanel Spacing="8" IsVisible="{Binding SelectedTask.IsLoopEnabled, FallbackValue=False}">
                            <RadioButton GroupName="LoopTrigger"
                                         Content="{localization:Loc Shortcut_PressToStartStop}"
                                         IsChecked="{Binding SelectedTask.LoopEnabled, Mode=TwoWay}"
                                         ToolTip.Tip="{localization:Loc Shortcut_PressToStartStopTooltip}"/>
                            <RadioButton GroupName="LoopTrigger"
                                         Content="{localization:Loc Shortcut_RunWhenHeld}"
                                         IsChecked="{Binding SelectedTask.RunWhileHeld, Mode=TwoWay}"
                                         ToolTip.Tip="{localization:Loc Shortcut_RunWhenHeldTooltip}"/>
                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,8,0"
                                            IsVisible="{Binding SelectedTask.LoopEnabled}">
                                    <TextBlock Classes="label" Text="{localization:Loc Shortcut_LoopCount}"/>
                                    <NumericUpDown Value="{Binding SelectedTask.RepeatCount, Mode=TwoWay}" Minimum="0" Maximum="10000" FormatString="0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4" Margin="8,0,0,0">
                                    <TextBlock Classes="label" Text="{localization:Loc Shortcut_LoopDelayMs}"/>
                                    <NumericUpDown Value="{Binding SelectedTask.RepeatDelayMs, Mode=TwoWay}" Minimum="0" Maximum="2147483647" Increment="100" FormatString="0"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Margin="0,4,0,0"
                                        IsVisible="{Binding SelectedTask.LoopEnabled}">
                                <TextBlock Text="💡" FontSize="12" Classes="caption emoji-icon"/>
                                <TextBlock Text="{localization:Loc Shortcut_LoopTip}" Classes="caption"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Macro File -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{localization:Loc Shortcut_MacroFile}" Classes="caption"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <Border Grid.Column="0" 
                                   Background="{DynamicResource BackgroundBrush}" 
                                   CornerRadius="6" 
                                   Padding="12,8"
                                   Margin="0,0,8,0">
                                <TextBlock Text="{Binding SelectedMacroFileName, FallbackValue={localization:Loc Shortcut_NoFileSelected}}" 
                                          VerticalAlignment="Center"
                                          TextTrimming="CharacterEllipsis"
                                          ToolTip.Tip="{Binding SelectedMacroFilePath, FallbackValue=''}"/>
                            </Border>
                            <Button Grid.Column="1" 
                                   Command="{Binding BrowseMacroCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="📂" Classes="emoji-icon"/>
                                    <TextBlock Text="{localization:Loc Shortcut_Browse}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Status Section -->
            <Border Background="{DynamicResource SurfaceColor}" 
                   CornerRadius="12" 
                   Padding="16"
                   IsVisible="{Binding HasSelectedTask}">
                <StackPanel Spacing="8">
                    <TextBlock Text="{localization:Loc Shortcut_Status}" 
                              FontWeight="SemiBold" 
                              Foreground="{DynamicResource TextSecondaryBrush}"
                              FontSize="12"/>
                    <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{localization:Loc Shortcut_LastTriggered}" Classes="caption"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" 
                                  Text="{Binding SelectedTask.LastTriggeredTime, StringFormat='{}{0:G}', TargetNullValue={localization:Loc Shortcut_Never}, FallbackValue={localization:Loc Shortcut_Never}}" 
                                  FontSize="12"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{localization:Loc Shortcut_StatusLabel}" Classes="caption"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                  Text="{Binding SelectedTask.LastStatus, TargetNullValue={localization:Loc Shortcut_StatusPlaceholder}, FallbackValue={localization:Loc Shortcut_StatusPlaceholder}}" 
                                  FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Save Button -->
            <Button Command="{Binding SaveCommand}"
                   Classes="primary"
                   HorizontalAlignment="Right"
                   IsVisible="{Binding HasSelectedTask}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="💾" Classes="emoji-icon"/>
                    <TextBlock Text="{localization:Loc Shortcut_SaveAll}"/>
                </StackPanel>
            </Button>
            
            <!-- Empty State -->
            <Border Background="{DynamicResource SurfaceColor}" 
                    CornerRadius="12" 
                    Padding="32"
                    IsVisible="{Binding !HasSelectedTask}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                    <TextBlock Text="⌨️" FontSize="48" Classes="emoji-icon" HorizontalAlignment="Center"/>
                    <TextBlock Text="{localization:Loc Shortcut_NoSelected}" 
                              FontSize="16" 
                              FontWeight="Medium"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="{localization:Loc Shortcut_SelectHint}" 
                              Classes="caption"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>
